# Server
PORT=4000
APP_URL=http://localhost:5173
JWT_SECRET=replace-with-a-long-random-string-at-least-32-chars

# MySQL (optional — omit to run with in-memory stores)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=project_health_inspector

# SMTP (optional — omit to print reset links to the console via ConsoleMailer)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=Project Health Inspector <no-reply@phi.local>
